{
  "name": "@repair-ops/display",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node -r ../../scripts/patch-readlink.cjs ../../node_modules/next/dist/bin/next dev --hostname 127.0.0.1 --port 3001",
    "build": "node -r ../../scripts/patch-readlink.cjs ../../node_modules/next/dist/bin/next build",
    "start": "node -r ../../scripts/patch-readlink.cjs ../../node_modules/next/dist/bin/next start --hostname 127.0.0.1 --port 3001",
    "start:docker": "node -r ../../scripts/patch-readlink.cjs ../../node_modules/next/dist/bin/next start --hostname 0.0.0.0 --port 3001"
  },
  "dependencies": {
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3"
  }
}
